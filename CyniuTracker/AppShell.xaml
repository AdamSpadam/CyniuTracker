<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="CyniuTracker.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:CyniuTracker"
       Title="CyniuTracker"
       Shell.FlyoutBehavior="Disabled"
       Shell.TabBarBackgroundColor="Black"
       Shell.TitleColor="White"
       Shell.BackgroundColor="Black"
       Shell.TabBarUnselectedColor="White"
       Shell.TabBarTitleColor="Aquamarine">
    <TabBar>
        <ShellContent Title="Home" ContentTemplate="{DataTemplate local:MainPage}" />
        <ShellContent Title="Watching" ContentTemplate="{DataTemplate local:NewPage1}" />
        <ShellContent Title="Settings" ContentTemplate="{DataTemplate local:Settings}" />
    </TabBar>
</Shell>